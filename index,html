<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Start Kids</title>
    
    <!-- Tailwind CSS untuk reka bentuk (Styling) -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel untuk kompilasi JSX dalam pelayar -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        /* Animasi Khas Kanak-Kanak & Scrollbar */
        @keyframes bounce-slow { 0%, 100% { transform: translateY(-5%); } 50% { transform: translateY(0); } }
        .animate-bounce-slow { animation: bounce-slow 3s ease-in-out infinite; }
        
        @keyframes pulse-slow { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }
        .animate-pulse-slow { animation: pulse-slow 2s ease-in-out infinite; }
        
        .custom-scrollbar::-webkit-scrollbar { width: 12px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.2); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.3); }
        
        body { margin: 0; padding: 0; background-color: #F8FAFC; font-family: sans-serif; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // --- SISTEM AUDIO (Text-to-Speech) ---
        const speakText = (text, rate = 0.8) => {
            if (!('speechSynthesis' in window)) {
                console.warn('Text-to-Speech tidak disokong pada pelayar ini.');
                return;
            }
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'ms-MY';
            utterance.rate = rate;
            utterance.pitch = 1.2;
            window.speechSynthesis.speak(utterance);
        };

        // --- FUNGSI PEMBANTU DATA ---
        const getMalayNumberText = (n) => {
            if (n === 0) return 'Sifar';
            if (n === 100) return 'Seratus';
            const sa = ['', 'Satu', 'Dua', 'Tiga', 'Empat', 'Lima', 'Enam', 'Tujuh', 'Lapan', 'Sembilan'];
            if (n < 10) return sa[n];
            if (n === 10) return 'Sepuluh';
            if (n === 11) return 'Sebelas';
            if (n < 20) return sa[n % 10] + ' belas';
            const puluh = Math.floor(n / 10);
            const baki = n % 10;
            return sa[puluh] + ' puluh' + (baki > 0 ? ' ' + sa[baki] : '');
        };

        const ALL_LETTERS = [
            { l: 'A', s: 'Ah', w: [{w: 'Ayam', i: '🐔'}, {w: 'Api', i: '🔥'}, {w: 'Awan', i: '☁️'}] },
            { l: 'B', s: 'Beh', w: [{w: 'Buku', i: '📖'}, {w: 'Bola', i: '⚽'}, {w: 'Baju', i: '👕'}] },
            { l: 'C', s: 'Ceh', w: [{w: 'Cawan', i: '☕'}, {w: 'Cincin', i: '💍'}, {w: 'Cacing', i: '🐛'}] },
            { l: 'D', s: 'Deh', w: [{w: 'Dadu', i: '🎲'}, {w: 'Daun', i: '🍃'}, {w: 'Durian', i: '🍈'}] },
            { l: 'E', s: 'Eh', w: [{w: 'Epal', i: '🍎'}, {w: 'Ekor', i: '🐕'}, {w: 'Enam', i: '6️⃣'}] },
            { l: 'F', s: 'Feh', w: [{w: 'Feri', i: '⛴️'}, {w: 'Foto', i: '🖼️'}, {w: 'Fikir', i: '🤔'}] },
            { l: 'G', s: 'Geh', w: [{w: 'Gajah', i: '🐘'}, {w: 'Gigi', i: '🦷'}, {w: 'Gunting', i: '✂️'}] },
            { l: 'H', s: 'Heh', w: [{w: 'Hutan', i: '🌲'}, {w: 'Hati', i: '💖'}, {w: 'Hidung', i: '👃'}] },
            { l: 'I', s: 'Eee', w: [{w: 'Ikan', i: '🐟'}, {w: 'Itik', i: '🦆'}, {w: 'Ibu', i: '👩'}] },
            { l: 'J', s: 'Jeh', w: [{w: 'Jari', i: '🖐️'}, {w: 'Jam', i: '⌚'}, {w: 'Jalan', i: '🛣️'}] },
            { l: 'K', s: 'Keh', w: [{w: 'Kucing', i: '🐈'}, {w: 'Kasut', i: '👟'}, {w: 'Kuda', i: '🐎'}] },
            { l: 'L', s: 'Leh', w: [{w: 'Lembu', i: '🐄'}, {w: 'Lilin', i: '🕯️'}, {w: 'Lebah', i: '🐝'}] },
            { l: 'M', s: 'Meh', w: [{w: 'Mata', i: '👁️'}, {w: 'Meja', i: '🪑'}, {w: 'Monyet', i: '🐒'}] },
            { l: 'N', s: 'Neh', w: [{w: 'Nasi', i: '🍚'}, {w: 'Nanas', i: '🍍'}, {w: 'Nyamuk', i: '🦟'}] },
            { l: 'O', s: 'Oh', w: [{w: 'Otak', i: '🧠'}, {w: 'Oren', i: '🍊'}, {w: 'Orang', i: '🧍'}] },
            { l: 'P', s: 'Peh', w: [{w: 'Pokok', i: '🌳'}, {w: 'Payung', i: '☂️'}, {w: 'Pen', i: '🖊️'}] },
            { l: 'Q', s: 'Qeh', w: [{w: 'Quran', i: '📖'}, {w: 'Qari', i: '👳'}] },
            { l: 'R', s: 'Reh', w: [{w: 'Rusa', i: '🦌'}, {w: 'Roti', i: '🍞'}, {w: 'Rumah', i: '🏠'}] },
            { l: 'S', s: 'Seh', w: [{w: 'Siput', i: '🐌'}, {w: 'Susu', i: '🥛'}, {w: 'Semut', i: '🐜'}] },
            { l: 'T', s: 'Teh', w: [{w: 'Topi', i: '🧢'}, {w: 'Tali', i: '🪢'}, {w: 'Tikus', i: '🐁'}] },
            { l: 'U', s: 'Ooo', w: [{w: 'Ular', i: '🐍'}, {w: 'Ubat', i: '💊'}, {w: 'Udang', i: '🦐'}] },
            { l: 'V', s: 'Veh', w: [{w: 'Van', i: '🚐'}, {w: 'Video', i: '📹'}, {w: 'Vase', i: '🏺'}] },
            { l: 'W', s: 'Weh', w: [{w: 'Wau', i: '🪁'}, {w: 'Wang', i: '💵'}, {w: 'Wayang', i: '🎭'}] },
            { l: 'X', s: 'Xeh', w: [{w: 'X-ray', i: '🦴'}, {w: 'Xilofon', i: '🎼'}] },
            { l: 'Y', s: 'Yeh', w: [{w: 'Yoyo', i: '🪀'}, {w: 'Yu', i: '🦈'}] },
            { l: 'Z', s: 'Zeh', w: [{w: 'Zirafah', i: '🦒'}, {w: 'Zip', i: '🤐'}, {w: 'Zaitun', i: '🫒'}] }
        ];

        const ALL_NUMBERS = Array.from({ length: 101 }, (_, i) => ({
            num: i,
            text: getMalayNumberText(i),
            countImg: i % 3 === 0 ? '🍎' : i % 2 === 0 ? '⭐' : '🎈'
        }));

        // --- PANGKALAN DATA PEMBELAJARAN ---
        const COURSE_DATA = {
            m1: {
                id: 'm1',
                title: 'Kenal Huruf A-Z',
                type: 'letter',
                color: 'bg-pink-200',
                textColor: 'text-pink-700',
                content: ALL_LETTERS.map(item => ({
                    letter: item.l, upper: item.l, lower: item.l.toLowerCase(), sound: item.l, words: item.w
                })),
                quiz: [
                    { question: 'Manakah huruf A?', options: ['B', 'A', 'M'], answer: 'A' },
                    { question: 'A untuk apa?', options: ['Bola', 'Ayam', 'Cawan'], answer: 'Ayam' },
                    { question: 'Manakah huruf Z?', options: ['Z', 'X', 'Y'], answer: 'Z' },
                    { question: 'Z untuk apa?', options: ['Zirafah', 'Gajah', 'Kucing'], answer: 'Zirafah' },
                    { question: 'Manakah huruf M?', options: ['W', 'N', 'M'], answer: 'M' }
                ]
            },
            m2: {
                id: 'm2',
                title: 'Bunyi Huruf (Fonik)',
                type: 'phonics',
                color: 'bg-blue-200',
                textColor: 'text-blue-700',
                requires: 'm1',
                content: ALL_LETTERS.map(item => ({
                    letter: item.l, sound: item.s, phonetic: item.s
                })),
                quiz: [
                    { question: 'Bunyi "Beh" untuk huruf apa?', options: ['A', 'D', 'B'], answer: 'B' },
                    { question: 'Bunyi "Ah" untuk huruf apa?', options: ['A', 'E', 'O'], answer: 'A' },
                    { question: 'Bunyi "Seh" untuk huruf apa?', options: ['C', 'S', 'Z'], answer: 'S' },
                    { question: 'Bunyi "Meh" untuk huruf apa?', options: ['N', 'W', 'M'], answer: 'M' },
                    { question: 'Bunyi "Keh" untuk huruf apa?', options: ['K', 'C', 'G'], answer: 'K' }
                ]
            },
            m3: {
                id: 'm3',
                title: 'Suku Kata (Vokal A)',
                type: 'syllable',
                color: 'bg-yellow-200',
                textColor: 'text-yellow-700',
                requires: 'm2',
                content: [
                    { syllable: 'ba', words: [{w: 'baju', img: '👕'}, {w: 'batu', img: '🪨'}, {w: 'bapa', img: '👨'}], sentence: 'Bapa ada baju.', story: 'Bapa Ali ada baju. Baju bapa baru.' },
                    { syllable: 'ca', words: [{w: 'cawan', img: '☕'}, {w: 'catur', img: '♟️'}], sentence: 'Ini cawan bapa.', story: 'Bapa minum guna cawan.' },
                    { syllable: 'da', words: [{w: 'dadu', img: '🎲'}, {w: 'dahan', img: '🌿'}], sentence: 'Abu ada dadu.', story: 'Abu main dadu sama Ali.' },
                    { syllable: 'fa', words: [{w: 'fasa', img: '🌙'}], sentence: 'Bulan ada fasa.', story: 'Bulan terang pada fasa penuh.' },
                    { syllable: 'ga', words: [{w: 'gajah', img: '🐘'}, {w: 'gasing', img: '🌀'}], sentence: 'Gajah itu besar.', story: 'Gajah ada belalai yang panjang.' },
                ],
                quiz: [
                    { question: 'Pilih suku kata "ba"', options: ['ca', 'ba', 'da'], answer: 'ba' },
                    { question: 'Gambar ini bermula dengan suku kata apa? (👕 Baju)', options: ['ca', 'ba', 'ga'], answer: 'ba' },
                    { question: 'Pilih suku kata "ga"', options: ['ga', 'ba', 'da'], answer: 'ga' }
                ]
            },
            m4: {
                id: 'm4',
                title: 'Kenal Nombor 0-100',
                type: 'number',
                color: 'bg-green-200',
                textColor: 'text-green-700',
                requires: 'm3',
                content: ALL_NUMBERS,
                quiz: [
                    { question: 'Manakah nombor Lima?', options: ['2', '5', '9'], answer: '5' },
                    { question: 'Manakah nombor Sepuluh?', options: ['10', '100', '1'], answer: '10' },
                    { question: 'Manakah nombor Lima Puluh?', options: ['15', '50', '5'], answer: '50' },
                    { question: 'Manakah nombor Seratus?', options: ['10', '100', '0'], answer: '100' },
                    { question: 'Kira buah epal ini: 🍎 🍎 🍎', options: ['Satu', 'Dua', 'Tiga'], answer: 'Tiga' }
                ]
            }
        };

        const MODULE_ORDER = ['m1', 'm2', 'm3', 'm4'];

        // --- KOMPONEN UI ---
        const Mascot = ({ message, mood = 'happy' }) => (
            <div className="flex items-end space-x-2 animate-bounce-slow">
                <div className="text-6xl">{mood === 'happy' ? '🐻' : '🐻‍❄️'}</div>
                <div className="bg-white p-3 rounded-2xl rounded-bl-none shadow-md border-2 border-pink-200 text-gray-700 font-bold max-w-[250px]">
                    {message}
                </div>
            </div>
        );

        const IconButton = ({ icon, onClick, className, text }) => (
            <button 
                onClick={onClick}
                className={`flex flex-col items-center justify-center p-3 rounded-2xl transition-transform transform hover:scale-105 active:scale-95 shadow-sm ${className}`}
            >
                <div className="text-2xl mb-1">{icon}</div>
                {text && <span className="font-bold text-sm text-gray-600">{text}</span>}
            </button>
        );

        // --- KOMPONEN PELAJARAN ---
        const LessonViewer = ({ module, onComplete, onExit }) => {
            const [phase, setPhase] = useState('grid');
            const [activeItem, setActiveItem] = useState(null);
            const [quizScore, setQuizScore] = useState(0);
            const [quizIndex, setQuizIndex] = useState(0);

            useEffect(() => {
                if (phase === 'grid') {
                    speakText(`Mari belajar ${module.title}. Pilih mana-mana kad!`);
                } else if (phase === 'quiz') {
                    speakText("Mari kita uji minda!");
                }
            }, [phase, module.title]);

            useEffect(() => {
                if (phase === 'detail' && activeItem) {
                    if (module.type === 'letter') speakText(activeItem.letter);
                    else if (module.type === 'phonics') speakText(activeItem.sound);
                    else if (module.type === 'syllable') speakText(activeItem.syllable);
                    else if (module.type === 'number') speakText(activeItem.text);
                }
            }, [activeItem, phase, module.type]);

            const handleQuizAnswer = (answer) => {
                if (answer === module.quiz[quizIndex].answer) {
                    speakText("Hebat! Betul.");
                    setQuizScore(prev => prev + 1);
                } else {
                    speakText("Cuba lagi ya.");
                }

                if (quizIndex < module.quiz.length - 1) {
                    setTimeout(() => setQuizIndex(quizIndex + 1), 1000);
                } else {
                    setTimeout(() => setPhase('result'), 1000);
                }
            };

            const finishModule = () => {
                const percentage = Math.round((quizScore / module.quiz.length) * 100);
                onComplete(percentage);
            };

            const renderGridPhase = () => (
                <div className="flex flex-col items-center justify-center space-y-6 w-full max-w-5xl mx-auto mt-4">
                    <Mascot message="Pilih mana-mana kad untuk belajar!" />
                    
                    <div className="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3 sm:gap-4 w-full h-[50vh] overflow-y-auto p-4 bg-white/50 rounded-3xl shadow-inner custom-scrollbar">
                        {module.content.map((item, idx) => (
                            <button
                                key={idx}
                                onClick={() => {
                                    setActiveItem(item);
                                    setPhase('detail');
                                }}
                                className={`${module.color} hover:brightness-95 active:scale-95 border-b-4 border-black/10 rounded-2xl aspect-square flex items-center justify-center text-3xl sm:text-4xl font-black shadow-sm transition-all`}
                            >
                                {module.type === 'letter' || module.type === 'phonics' ? item.upper : 
                                 module.type === 'syllable' ? item.syllable : item.num}
                            </button>
                        ))}
                    </div>

                    <button 
                        onClick={() => setPhase('quiz')}
                        className="mt-8 bg-gradient-to-r from-orange-400 to-red-500 text-white px-10 py-5 rounded-full font-black text-2xl shadow-xl hover:scale-105 active:scale-95 transition-all flex items-center"
                    >
                        ⭐ Uji Minda Sekarang!
                    </button>
                </div>
            );

            const renderDetailPhase = () => {
                if (!activeItem) return null;
                
                return (
                    <div className="flex flex-col items-center justify-start space-y-6 w-full max-w-3xl mx-auto mt-2 pb-10">
                        <button 
                            onClick={() => setPhase('grid')}
                            className="self-start bg-white px-6 py-3 rounded-full font-bold text-gray-600 shadow-sm flex items-center hover:bg-gray-50 active:scale-95 transition-transform"
                        >
                            ⬅️ Kembali
                        </button>

                        <div 
                            className="bg-white rounded-[3rem] p-8 md:p-12 shadow-2xl border-4 border-white flex flex-col items-center justify-center w-full min-h-[300px] cursor-pointer hover:scale-[1.02] transition-transform"
                            onClick={() => {
                                 if(module.type === 'letter') speakText(activeItem.letter);
                                 else if(module.type === 'syllable') speakText(activeItem.syllable);
                                 else speakText(activeItem.text || activeItem.sound);
                            }}
                        >
                            {module.type === 'letter' && (
                                <div className="text-[8rem] md:text-[12rem] leading-none font-black text-pink-500 animate-pulse-slow">
                                    {activeItem.upper}{activeItem.lower}
                                </div>
                            )}
                            
                            {module.type === 'syllable' && (
                                <div className="text-[6rem] md:text-[8rem] leading-none font-black text-yellow-500">
                                    {activeItem.syllable}
                                </div>
                            )}

                            {module.type === 'number' && (
                                <div className="flex flex-col items-center">
                                     <div className="text-[8rem] md:text-[12rem] leading-none font-black text-green-500">{activeItem.num}</div>
                                     <div className="text-3xl font-bold text-green-700 bg-green-100 px-6 py-2 rounded-full mt-4 uppercase tracking-widest">{activeItem.text}</div>
                                </div>
                            )}

                            {module.type === 'phonics' && (
                                <div className="flex flex-col items-center">
                                    <div className="text-[8rem] md:text-[12rem] leading-none font-black text-blue-500">{activeItem.letter}</div>
                                    <div className="text-3xl md:text-4xl font-bold text-gray-600 mt-4 px-6 py-3 bg-gray-100 rounded-full border-2 border-gray-200">
                                        Bunyi: "{activeItem.phonetic}"
                                    </div>
                                </div>
                            )}

                            <div className="mt-8 bg-blue-50 text-blue-600 p-4 rounded-full animate-bounce text-3xl">
                                🔊
                            </div>
                        </div>

                        {(module.type === 'letter' || module.type === 'syllable') && activeItem.words && (
                            <div className="grid grid-cols-2 md:grid-cols-3 gap-4 w-full">
                                {activeItem.words.map((word, idx) => (
                                    <button 
                                        key={idx}
                                        onClick={() => speakText(`${activeItem.letter || activeItem.syllable} untuk ${word.w}`)}
                                        className="bg-white p-6 rounded-3xl shadow-lg border-2 border-transparent hover:border-pink-300 flex flex-col items-center justify-center hover:scale-105 transition-transform"
                                    >
                                        <div className="text-7xl mb-4">{word.i || word.img}</div>
                                        <div className="font-bold text-2xl text-gray-700 capitalize">{word.w}</div>
                                    </button>
                                ))}
                            </div>
                        )}

                        {module.type === 'number' && activeItem.num > 0 && (
                            <div className="bg-white/60 p-6 rounded-3xl w-full">
                                 <div className="flex flex-wrap justify-center gap-2 max-h-[300px] overflow-y-auto">
                                     {[...Array(Math.min(activeItem.num, 100))].map((_, i) => (
                                          <div key={i} className="text-4xl md:text-5xl animate-bounce-slow" style={{animationDelay: `${(i % 10) * 0.1}s`}}>
                                              {activeItem.countImg}
                                          </div>
                                     ))}
                                 </div>
                                 {activeItem.num > 100 && <div className="text-center font-bold text-gray-500 mt-4">+ banyak lagi!</div>}
                            </div>
                        )}
                    </div>
                );
            };

            const renderQuizPhase = () => {
                const currentQuiz = module.quiz[quizIndex];
                return (
                    <div className="flex flex-col items-center justify-center space-y-8 w-full max-w-3xl mx-auto mt-12">
                        <Mascot message="Semoga berjaya!" />
                        
                        <div className="bg-white rounded-[3rem] p-8 md:p-12 shadow-2xl w-full text-center border-t-8 border-yellow-400">
                            <div className="text-gray-400 font-bold mb-6 tracking-widest uppercase">Soalan {quizIndex + 1} / {module.quiz.length}</div>
                            <h2 className="text-3xl md:text-5xl font-black text-gray-800 mb-10 leading-tight cursor-pointer" onClick={() => speakText(currentQuiz.question)}>
                                {currentQuiz.question} <span className="inline-block ml-2 text-3xl">🔊</span>
                            </h2>
                            
                            <div className="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                                {currentQuiz.options.map((opt, idx) => (
                                    <button 
                                        key={idx}
                                        onClick={() => handleQuizAnswer(opt)}
                                        className="bg-gray-50 hover:bg-yellow-100 border-4 border-gray-100 hover:border-yellow-400 rounded-3xl p-8 text-4xl md:text-5xl font-black transition-all text-gray-700 active:scale-95 shadow-sm"
                                    >
                                        {opt}
                                    </button>
                                ))}
                            </div>
                        </div>
                    </div>
                );
            };

            const renderResultPhase = () => {
                const percentage = Math.round((quizScore / module.quiz.length) * 100);
                const passed = percentage >= 80;

                useEffect(() => {
                    if (passed) speakText("Tahniah! Anda berjaya melepasi tahap ini.");
                    else speakText("Tidak mengapa, mari kita cuba lagi.");
                }, [passed]);

                return (
                    <div className="flex flex-col items-center justify-center space-y-8 mt-12 text-center bg-white p-12 rounded-[3rem] shadow-xl max-w-2xl mx-auto">
                        <div className="text-[8rem] mb-4 animate-bounce-slow">
                            {passed ? '🏆' : '💪'}
                        </div>
                        <h2 className={`text-5xl md:text-6xl font-black ${passed ? 'text-green-500' : 'text-orange-500'}`}>
                            {passed ? 'Tahniah!' : 'Cuba Lagi!'}
                        </h2>
                        <div className="text-4xl font-bold text-gray-700 bg-gray-50 px-10 py-5 rounded-full border-4 border-gray-100 shadow-inner">
                            Markah: {percentage}%
                        </div>
                        
                        <p className="text-2xl text-gray-600 font-medium">
                            {passed 
                                ? 'Anda sudah bersedia untuk modul seterusnya. Teruskan usaha hebat anda!' 
                                : 'Anda perlukan 80% untuk lulus. Jangan putus asa!'}
                        </p>

                        <button 
                            onClick={finishModule}
                            className={`${passed ? 'bg-green-500 hover:bg-green-600' : 'bg-blue-500 hover:bg-blue-600'} text-white px-12 py-6 rounded-full font-black text-3xl shadow-xl active:scale-95 transition-all mt-8 w-full md:w-auto`}
                        >
                            {passed ? 'Seterusnya' : 'Ulang Kuiz'}
                        </button>
                    </div>
                );
            };

            return (
                <div className="w-full h-full min-h-screen bg-slate-50 p-4 md:p-8 font-sans">
                    <div className="flex justify-between items-center mb-8 bg-white p-4 md:p-6 rounded-[2rem] shadow-sm">
                        <div className="flex items-center space-x-4">
                            <button onClick={onExit} className="bg-gray-100 p-4 rounded-2xl hover:bg-gray-200 active:scale-95 transition-colors text-2xl">
                                🏠
                            </button>
                            <div className={`w-16 h-16 rounded-2xl flex items-center justify-center text-white font-black text-2xl shadow-md ${module.color}`}>
                                {module.id.toUpperCase()}
                            </div>
                            <h1 className="text-2xl md:text-4xl font-black text-gray-800">{module.title}</h1>
                        </div>
                    </div>

                    {phase === 'grid' && renderGridPhase()}
                    {phase === 'detail' && renderDetailPhase()}
                    {phase === 'quiz' && renderQuizPhase()}
                    {phase === 'result' && renderResultPhase()}
                </div>
            );
        };

        // --- APP UTAMA ---
        const App = () => {
            const [currentScreen, setCurrentScreen] = useState('home');
            const [activeModuleId, setActiveModuleId] = useState(null);
            const [progress, setProgress] = useState({
                m1: { status: 'unlocked', score: 0 },
                m2: { status: 'locked', score: 0 },
                m3: { status: 'locked', score: 0 },
                m4: { status: 'locked', score: 0 },
            });

            const handleStartModule = (moduleId) => {
                if (progress[moduleId].status === 'locked') {
                    speakText("Kunci! Habiskan pelajaran sebelum ini dahulu.");
                    return;
                }
                setActiveModuleId(moduleId);
                setCurrentScreen('lesson');
            };

            const handleLessonComplete = (score) => {
                const isPassed = score >= 80;
                setProgress(prev => {
                    const newProgress = { ...prev };
                    newProgress[activeModuleId] = {
                        status: isPassed ? 'completed' : 'unlocked',
                        score: Math.max(prev[activeModuleId].score, score)
                    };

                    if (isPassed) {
                        const currentIndex = MODULE_ORDER.indexOf(activeModuleId);
                        if (currentIndex < MODULE_ORDER.length - 1) {
                            const nextModuleId = MODULE_ORDER[currentIndex + 1];
                            if (newProgress[nextModuleId].status === 'locked') {
                                 newProgress[nextModuleId] = { ...newProgress[nextModuleId], status: 'unlocked' };
                            }
                        }
                    }
                    return newProgress;
                });
                setCurrentScreen('home');
            };

            const renderDashboard = () => (
                <div className="min-h-screen bg-[#F8FAFC] p-4 md:p-8 font-sans pb-24 md:pb-8">
                    <header className="flex justify-between items-center bg-white p-4 md:p-6 rounded-[2rem] shadow-sm mb-8">
                        <div className="flex items-center space-x-4">
                            <div className="bg-gradient-to-br from-pink-400 to-purple-500 text-white p-4 rounded-2xl shadow-lg text-3xl">🌈</div>
                            <div>
                                <h1 className="text-3xl md:text-4xl font-black text-gray-800 tracking-tight">Smart Start Kids</h1>
                                <p className="text-sm font-bold text-gray-500 uppercase tracking-widest mt-1">Belajar ABC & Mengira</p>
                            </div>
                        </div>
                        <div className="hidden md:flex space-x-2">
                            <div className="flex items-center space-x-3 bg-yellow-50 text-yellow-600 border-2 border-yellow-200 px-6 py-3 rounded-2xl font-black text-xl shadow-sm">
                                <span>⭐</span>
                                <span>{Object.values(progress).filter(p => p.status === 'completed').length * 100} Mata</span>
                            </div>
                        </div>
                    </header>

                    <div className="bg-gradient-to-r from-cyan-400 to-blue-500 rounded-[2.5rem] p-10 md:p-16 text-white shadow-xl mb-12 relative overflow-hidden">
                        <div className="relative z-10 max-w-2xl">
                            <h2 className="text-4xl md:text-6xl font-black mb-4 leading-tight">Hai, Kawan Pintar! 👋</h2>
                            <p className="text-xl md:text-3xl font-medium opacity-90 leading-relaxed">Jom mula pengembaraan seronok hari ini.</p>
                        </div>
                        <div className="absolute right-[-40px] bottom-[-40px] text-[200px] md:text-[250px] opacity-20 transform -rotate-12">🚀</div>
                    </div>

                    <div className="max-w-6xl mx-auto">
                        <h3 className="text-3xl font-black text-gray-800 mb-8 flex items-center">
                            <span className="mr-4 text-3xl">🏅</span> Peta Pembelajaran
                        </h3>
                        
                        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 relative">
                            {MODULE_ORDER.map((moduleId, index) => {
                                const modData = COURSE_DATA[moduleId];
                                const modProgress = progress[moduleId];
                                const isLocked = modProgress.status === 'locked';
                                const isCompleted = modProgress.status === 'completed';

                                return (
                                    <div 
                                        key={moduleId}
                                        onClick={() => handleStartModule(moduleId)}
                                        className={`
                                            relative rounded-[2.5rem] p-8 border-b-[10px] transition-all cursor-pointer shadow-lg
                                            ${isLocked 
                                                ? 'bg-gray-100 border-gray-300 opacity-80 grayscale' 
                                                : `${modData.color} ${isCompleted ? 'border-green-500' : 'border-black/20 hover:-translate-y-2 active:translate-y-2'}`
                                            }
                                        `}
                                    >
                                        <div className="absolute -top-6 -right-4">
                                            {isLocked && <div className="bg-gray-600 p-4 rounded-full shadow-xl text-white text-2xl">🔒</div>}
                                            {isCompleted && <div className="bg-green-500 p-4 rounded-full shadow-xl text-white text-2xl animate-bounce-slow">✅</div>}
                                        </div>

                                        <div className="text-[5rem] mb-6 text-center filter drop-shadow-md">
                                            {moduleId === 'm1' ? '🅰️' : moduleId === 'm2' ? '🔊' : moduleId === 'm3' ? '📚' : '🔢'}
                                        </div>
                                        
                                        <h4 className={`text-2xl font-black text-center mb-4 leading-tight ${isLocked ? 'text-gray-500' : modData.textColor}`}>
                                            {modData.title}
                                        </h4>
                                        
                                        {!isLocked && (
                                            <div className="mt-auto pt-4 flex justify-between items-center text-lg font-bold bg-white/60 py-3 px-5 rounded-2xl">
                                                <span className="text-gray-600">Markah</span>
                                                <span className={modProgress.score >= 80 ? 'text-green-600 font-black' : 'text-orange-600 font-black'}>
                                                    {modProgress.score}%
                                                </span>
                                            </div>
                                        )}
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                    
                    {/* Mobile Bottom Navigation */}
                    <div className="fixed bottom-0 left-0 right-0 p-4 bg-white border-t border-gray-100 flex justify-around pb-8 shadow-[0_-20px_40px_rgba(0,0,0,0.08)] rounded-t-[2.5rem] md:hidden z-50">
                         <IconButton icon="🏠" text="Utama" />
                         <IconButton icon="⭐" text="Skor" />
                         <IconButton icon="😊" text="Profil" />
                    </div>
                </div>
            );

            return (
                <div className="font-sans antialiased text-gray-900 selection:bg-pink-300 min-h-screen">
                    {currentScreen === 'home' && renderDashboard()}
                    {currentScreen === 'lesson' && activeModuleId && (
                        <LessonViewer 
                            module={COURSE_DATA[activeModuleId]} 
                            onComplete={handleLessonComplete}
                            onExit={() => setCurrentScreen('home')}
                        />
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
